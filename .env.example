# DomusAI Configuration

# Application
NODE_ENV=development
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=DEBUG
PORT=3000

# API Configuration
API_PREFIX=/api
API_VERSION=v1

# External APIs
PROPERTY_API_KEY=your_api_key_here
PROPERTY_API_URL=https://api.immobiliare.it

MARKET_DATA_API_KEY=your_api_key_here
MARKET_DATA_API_URL=https://api.market.data

# LLM Configuration (for AI capabilities)
OPENAI_API_KEY=your_openai_key_here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7

# Database (for future integration)
DATABASE_URL=postgresql://user:password@localhost:5432/domusai
DATABASE_SYNC=true

# Logging
LOG_FORMAT=json

# Security
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=24h

# Webhooks
WEBHOOK_SECRET=your_webhook_secret

