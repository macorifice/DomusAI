# DomusAI Configuration

# Application
NODE_ENV=development
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=DEBUG
PORT=3000

# API Configuration
API_PREFIX=/api
API_VERSION=v1

# External APIs - Portali immobiliari
IDEALISTA_API_KEY=your_idealista_api_key
IDEALISTA_API_URL=https://api.idealista.com

IMMOBILIARE_API_KEY=your_immobiliare_api_key
IMMOBILIARE_API_URL=https://api.immobiliare.it

CASA_IT_API_KEY=your_casa_it_api_key
CASA_IT_API_URL=https://api.casa.it

MARKET_DATA_API_KEY=your_market_data_api_key
MARKET_DATA_API_URL=https://api.market.data

# OpenAPI Real Estate (zone pricing benchmark)
REALESTATE_OPENAPI_BEARER_TOKEN=your_openapi_realestate_bearer_token
REALESTATE_OPENAPI_URL=https://test.realestate.openapi.com

# LLM Configuration (for AI capabilities)
OPENAI_API_KEY=your_openai_key_here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7

# Database (for future integration)
DATABASE_URL=postgresql://user:password@localhost:5432/domusai
DATABASE_SYNC=true
LISTING_CACHE_TTL_MS=300000

# Supabase (checklist, stato workflow purchase_workflows, trigger profili)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# JWT Secret (legacy HS256, Settings > JWT) — solo se i token usano ancora algoritmo HS256
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
# Opzionale: se `iss` sul JWT non coincide con SUPABASE_URL/auth/v1 (es. dominio custom)
# SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1

# Logging
LOG_FORMAT=json

# Security
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=24h

# Webhooks
WEBHOOK_SECRET=your_webhook_secret

