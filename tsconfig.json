{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "lib": ["ES2021"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": "./",
    "paths": {
      "@agents/*": ["src/agents/*"],
      "@workflows/*": ["src/workflows/*"],
      "@models/*": ["src/models/*"],
      "@tools/*": ["src/tools/*"],
      "@common/*": ["src/common/*"],
      "@cache/*": ["src/cache/*"],
      "@search-rules/*": ["src/search-rules/*"],
      "@auth/*": ["src/auth/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "**/*spec.ts"]
}
