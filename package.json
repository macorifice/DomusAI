{
  "name": "domusai",
  "version": "0.1.0",
  "description": "DomusAI - Workflow agentico intelligente per l'acquisto della casa",
  "author": "DomusAI Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "build:frontend": "NODE_ENV=production npm run build --prefix frontend",
    "build:all": "npm run build && npm run build:frontend",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:frontend": "WATCHPACK_POLLING=true npm run dev --prefix frontend",
    "start:dev:all": "concurrently \"npm run start:dev\" \"npm run start:frontend\"",
    "ports:free": "kill-port 3000 3001",
    "start:dev:all:clean": "npm run ports:free && npm run start:dev:all",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint --no-eslintrc --config .eslintrc.js \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:frontend": "npm run lint --prefix frontend",
    "test": "jest --watchman=false",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@supabase/supabase-js": "^2.105.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "kill-port": "^2.0.1",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
